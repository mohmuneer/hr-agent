{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/frontend/(.*)", "dest": "/frontend/$1" },
    { "src": "/apply", "dest": "/api/index.py" },
    { "src": "/login", "dest": "/api/index.py" },
    { "src": "/interview", "dest": "/api/index.py" },
    { "src": "/app", "dest": "/api/index.py" },
    { "src": "/api/v1/(.*)", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
