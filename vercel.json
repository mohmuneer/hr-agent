{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/(apply|login|interview|health)", "destination": "/api/index.py" },
    { "source": "/app(/?.*)", "destination": "/api/index.py" },
    { "source": "/api/v1/(.*)", "destination": "/api/index.py" },
    { "source": "/", "destination": "/api/index.py" }
  ]
}
