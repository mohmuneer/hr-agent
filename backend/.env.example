# مزوّد النموذج: anthropic أو gemini
HR_AGENT_PROVIDER=anthropic

# مطلوب فقط إذا كان HR_AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
HR_AGENT_MODEL=claude-sonnet-4-5

# مطلوب فقط إذا كان HR_AGENT_PROVIDER=gemini (مفتاح مجاني من https://aistudio.google.com/apikey)
GEMINI_API_KEY=
HR_AGENT_GEMINI_MODEL=gemini-2.5-flash

# PostgreSQL connection string (required)
# DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://hr_agent:hr_agent@localhost:5432/hr_agent

HR_AGENT_DOMAIN=accounting

# بيانات دخول لوحة HR الداخلية — غيّرها إلزاميًا قبل أي استخدام فعلي
HR_ADMIN_USERNAME=admin
HR_ADMIN_PASSWORD=changeme123

# CORS — النطاقات المسموح بها (افصل بينها بفاصلة، مثال: https://example.com,https://app.example.com)
# CORS_ORIGINS=https://your-domain.com

# SMTP — إشعارات البريد الإلكتروني للمرشحين (اختياري)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=HR Agent <your-email@gmail.com>
